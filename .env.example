# =============================================================================
# KfSmart 环境变量样例
# 复制为 .env 后填入真实值。.env 已被 .gitignore 忽略，切勿提交。
#
# 安全提示：
#   - 历史已泄漏的 JWT 密钥与 docker MinIO 真实凭证必须立即轮换。
#   - 生产环境所有口令使用强随机值，禁止使用下列兜底弱口令。
#   - application*.yml 中的 ${ENV:默认} 仅作本地开发兜底，生产由本文件/真实环境变量覆盖。
# =============================================================================

# ---- MySQL ----
MYSQL_URL=jdbc:mysql://localhost:3306/knowflow?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-strong-password

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-password

# ---- MinIO ----
MINIO_ENDPOINT=http://localhost:19000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me-strong-secret
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me-strong-secret
MINIO_BUCKET=uploads
MINIO_PUBLIC_URL=http://localhost:19000

# ---- JWT（HMAC 签名密钥，生产必须为高强度随机串并定期轮换）----
JWT_SECRET_KEY=change-me-to-a-long-high-entropy-random-string

# ---- 管理员初始化账号 ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# ---- Elasticsearch ----
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
ES_USERNAME=elastic
ES_PASSWORD=change-me-strong-password

# ---- AI / Embedding 模型 ----
AI_DEFAULT_URL=https://api.deepseek.com/v1
AI_DEFAULT_MODEL=deepseek-chat
AI_DEFAULT_KEY=sk-your-llm-api-key
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-your-embedding-api-key

# ---- 危险操作二次确认密钥（AdminController clearAllData / migrateMinioFiles）----
ADMIN_DANGEROUS_CLEAR_KEY=change-me-random-opaque-token
ADMIN_DANGEROUS_MIGRATE_KEY=change-me-random-opaque-token

# ---- 工作流节点安全配置 ----
# 代码执行节点：沙箱未接入前默认禁用（即便设为 true，仍因 sandbox 未就绪而拒绝执行）
WORKFLOW_CODE_NODE_ENABLED=false
WORKFLOW_CODE_NODE_TIMEOUT_MS=5000
WORKFLOW_SQL_NODE_QUERY_TIMEOUT_SECONDS=10
# 可选：工作流 SQL 节点独立只读 DataSource（深度防御，推荐使用只读权限账号；留空则回退主库）
# WORKFLOW_SQL_READONLY_URL=jdbc:mysql://localhost:3306/knowflow?useSSL=false&serverTimezone=UTC
# WORKFLOW_SQL_READONLY_USERNAME=readonly_user
# WORKFLOW_SQL_READONLY_PASSWORD=change-me-readonly-password
# WORKFLOW_SQL_READONLY_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
